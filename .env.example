NUXT_PUBLIC_CREATOR_CALLBACK_URI= # use "https://localhost:3000"
# Dashboard settings
NUXT_BACKOFFICE_SKIP_ROLES=false # Should app check for user's role/permissions
NUXT_BACKOFFICE_MONGO= # Mongo connection URL
# General
NUXT_PUBLIC_REDFLARE_ENV= # development | staging | production | etc...