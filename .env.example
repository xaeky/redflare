# Credentials @ PayPal # https://developer.paypal.com/dashboard/
NUXT_PP_CID= # Client ID
NUXT_PP_SID= # Secret token
NUXT_PP_ENDPOINT_BASE=
# OAuth
NUXT_OAUTH_AUTH0_CLIENT_ID=
NUXT_OAUTH_AUTH0_CLIENT_SECRET=
NUXT_OAUTH_AUTH0_DOMAIN=
NUXT_OAUTH_AUTH0_REDIRECT_URL= # use "https://localhost:3000/api/auth/auth0" for local env.
